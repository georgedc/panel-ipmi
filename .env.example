# Database
DB_HOST=localhost
DB_NAME=ipmi_panel
DB_USER=your_db_user
DB_PASS=your_db_password

# Application
APP_NAME="IPMI Control Panel"
APP_URL=https://your-domain.com/ipmi-panel
APP_VERSION=1.0.0

# Session
SESSION_LIFETIME=3600
HASH_COST=12
SESSION_NAME=ipmi_session

# Debug (set to false in production)
DEBUG_MODE=false
LOG_ACTIONS=true

# Allowed IPs for internal API (comma separated)
INTERNAL_API_ALLOWED_IPS=127.0.0.1

# Shared secret between WHMCS and this panel
WHMCS_SSO_SECRET=change_this_to_a_random_secret

# CORS origin for WHMCS requests
WHMCS_ORIGIN=https://your-whmcs-domain.com
